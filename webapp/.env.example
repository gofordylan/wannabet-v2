# Indexer (Ponder) API base URL. Defaults to the hosted instance if unset.
NEXT_PUBLIC_INDEXER_URL=

# Public app URL, used for share links + OG metadata (e.g. https://app.heywannabet.com)
NEXT_PUBLIC_BASE_URL=

# Base mainnet RPC for client-side wallet reads (optional; defaults to https://mainnet.base.org)
NEXT_PUBLIC_BASE_RPC_URL=

# Ethereum mainnet RPC used for ENS resolution in the user-search API route
# (optional; defaults to a free public node)
MAINNET_RPC_URL=
